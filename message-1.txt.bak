            local part = p.Character and p.Character:FindFirstChild(pname)
            if part then
                pcall(function() RA:FireServer() end)
                pcall(function() RH:FireServer(part, {{p.Character, part}}, nil, nil, "buff") end)
            end
        end
    end
})

